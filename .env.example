# =============================================================================
# Databas för delade gäng (Turso / libSQL)
# =============================================================================
# Delade gäng kräver en persistent serverdatabas. Utan DATABASE_URL sparas data
# bara i en lokal fil som nollställs vid varje Vercel-deploy.
#
# Snabbaste sättet:
#   1. Installera Turso CLI:  curl -sSfL https://get.tur.so/install.sh | bash
#   2. Logga in:             turso auth login
#   3. Kör setup:            npm run db:setup-turso
#   4. Lägg in variablerna från .env.local i Vercel (se nedan)
#
# Alternativ: Vercel Marketplace → Turso-integration (sätter variablerna åt dig)
# =============================================================================

# Lokal utveckling (fil-baserad SQLite, ingen delning mellan deploys):
# DATABASE_URL=file:./data/badloggen.db

# Produktion (Turso) — skapas automatiskt av npm run db:setup-turso:
# DATABASE_URL=libsql://badloggen-<org>.turso.io
# DATABASE_AUTH_TOKEN=eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9...
